# PT — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Supabase (required) ──────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/dvevwlhshcyvnsubyvzw/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://dvevwlhshcyvnsubyvzw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ─── Markets API (optional) ───────────────────────────────────────────────────
# Token to protect /api/markets from public abuse (set any random string)
MARKETS_API_TOKEN=change_this_for_production

# ─── Featured Markets (optional) ─────────────────────────────────────────────
# If set, /api/polymarket serves these markets instead of live Polymarket data.
# Remove this var in production to use live Polymarket Gamma API.
FEATURED_MARKETS_JSON=[{"id":"1","title":"US Presidential Election 2028","platform":"Polymarket","outcome":"Yes","url":"https://polymarket.com","category":"politics"},{"id":"2","title":"Bitcoin > $150k by Dec 2026","platform":"Polymarket","outcome":"Yes","url":"https://polymarket.com","category":"crypto"}]

# ─── AI Features (optional — Phase 4g, not yet active) ───────────────────────
# Add this when activating AI market summaries and share copy generation.
# ANTHROPIC_API_KEY=sk-ant-...
